// Online C++ compiler to run C++ program online
#include <iostream>
using namespace std;

int expo(int a, int b, int result = 1) {
    if(b==0)
        return result;
    else {
        result = a * expo(a,b-1, result);
    }
}

int fuck(int a, int result = 1) {
    if(a==0)
        return result;
    else {
        result = a * fuck(a-1, result);
    }
}

int main() {
    
    cout << expo(2,5) << endl;
    cout << fuck(5);
    return 0;
}
